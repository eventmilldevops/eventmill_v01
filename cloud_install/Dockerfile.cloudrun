# Event Mill v0.1.0 - Cloud Run Deployment with ttyd web terminal
# Cloud Run provides HTTPS on port 443 automatically, routing to container PORT (8080)
#
# Multi-stage build:
#   Stage 1 (builder): Install Python dependencies
#   Stage 2 (runtime): Minimal image with ttyd + eventmill

# ---------------------------------------------------------------------------
# Stage 1: Builder
# ---------------------------------------------------------------------------
FROM python:3.12-slim-bookworm AS builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy dependency manifest and install with GCP + plugin extras
# gcp:                  google-cloud-storage, secret-manager, logging
# plugins-threat-modeling: pypdf (PDF extraction for threat_report_analyzer)
# plugins-log-analysis: pdfplumber, beautifulsoup4, python-docx, stix2 (for threat_intel_ingester)
COPY pyproject.toml README.md ./
RUN pip install --no-cache-dir build && \
    pip install --no-cache-dir ".[gcp,plugins-threat-modeling,plugins-log-analysis,plugins-network-forensics]"

# ---------------------------------------------------------------------------
# Stage 2: Runtime
# ---------------------------------------------------------------------------
FROM python:3.12-slim-bookworm

# Install ttyd from official release and minimal runtime deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    ca-certificates \
    libmagic1 \
    && wget -qO /usr/local/bin/ttyd \
       https://github.com/tsl0922/ttyd/releases/download/1.7.7/ttyd.x86_64 \
    && chmod +x /usr/local/bin/ttyd \
    && apt-get purge -y wget \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

# Create non-privileged user
RUN groupadd --gid 1000 eventmill \
    && useradd --uid 1000 --gid eventmill --shell /bin/bash --create-home eventmill

WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application code
COPY --chown=eventmill:eventmill framework/ ./framework/
COPY --chown=eventmill:eventmill plugins/ ./plugins/
COPY --chown=eventmill:eventmill pyproject.toml README.md ./

# Create workspace directory
# Note: GCS access uses workload identity (no credentials file needed)
RUN mkdir -p /app/workspace/sessions /app/workspace/artifacts /app/workspace/logs \
    && chown -R eventmill:eventmill /app/workspace

# Switch to non-privileged user
USER eventmill

# Cloud Run sets PORT env var (default 8080)
# ttyd listens on this port, Cloud Run proxies HTTPS:443 -> container:PORT
ENV PORT=8080
ENV PYTHONUNBUFFERED=1
ENV EVENTMILL_WORKSPACE=/app/workspace
ENV EVENTMILL_LOG_LEVEL=INFO

# LLM API keys are injected via Cloud Run secrets (--set-secrets in deploy script):
#   GEMINI_FLASH_API_KEY - Gemini Flash (light tier, fast/cheap)
#   GEMINI_PRO_API_KEY   - Gemini Pro (heavy tier, powerful)
# The shell auto-detects available models from these environment variables.

EXPOSE 8080

# ttyd options:
#   -W              = writable (allow input)
#   -p $PORT        = listen on Cloud Run's PORT
#   -t fontSize=16  = larger font for readability
#   -c user:pass    = basic auth (optional, use with Secret Manager)
#   --ping-interval = WebSocket ping interval (seconds) to keep the
#                     connection alive through Cloud Run's LB / proxy.
#                     Without this, idle connections during long LLM calls
#                     are dropped after ~60-90 s.
#
# For public access without auth (Cloud Run IAM handles access):
# CMD ["sh", "-c", "ttyd -W -p ${PORT} --ping-interval 30 -t fontSize=16 python -m framework.cli.shell"]
#
# For basic auth (set TTYD_USERNAME and TTYD_PASSWORD as secrets):
CMD ["sh", "-c", "ttyd -W -p ${PORT} -c ${TTYD_USERNAME}:${TTYD_PASSWORD} --ping-interval 30 -t fontSize=16 python -m framework.cli.shell"]

# Event Mill Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# MCP Configuration
# =============================================================================

# MCP transport type: stdio or sse
EVENTMILL_MCP_TRANSPORT=stdio

# Model provider endpoint (provider-specific)
EVENTMILL_MCP_ENDPOINT=

# Model tiers — plugins declare model_tier in their manifest.json
# Heavy: deep reasoning tasks (threat modeling, attack paths, risk assessment)
EVENTMILL_MODEL_HEAVY=gemini-2.5-pro
# Light: bulk operations (log reading, pattern scanning, report ingestion)
EVENTMILL_MODEL_LIGHT=gemini-2.5-flash

# =============================================================================
# Google Cloud Platform (optional, for GCP deployment)
# =============================================================================

# Path to service account key file
GOOGLE_APPLICATION_CREDENTIALS=

# GCS bucket for artifact storage (single-bucket legacy mode)
GCS_ARTIFACT_BUCKET=

# Bucket prefix for pillar-based storage (recommended)
# Buckets created: {prefix}-log-analysis, {prefix}-network-forensics,
#                  {prefix}-threat-modeling, {prefix}-common
# Convention: {project_id}-eventmill
EVENTMILL_BUCKET_PREFIX=

# GCP project ID
GCP_PROJECT_ID=

# GCP region
GCP_REGION=us-central1

# =============================================================================
# API Keys (provider-specific)
# =============================================================================

# Gemini API keys — one per model tier to isolate quota and billing
# Get keys from: https://aistudio.google.com/apikey
# Using separate keys prevents high-volume Flash calls from affecting Pro quota
GEMINI_FLASH_API_KEY=
GEMINI_PRO_API_KEY=

# Anthropic API key (for Claude)
ANTHROPIC_API_KEY=

# OpenAI API key (for GPT)
OPENAI_API_KEY=

# =============================================================================
# Runtime Configuration
# =============================================================================

# Workspace directory for sessions, artifacts, logs
EVENTMILL_WORKSPACE=./workspace

# Log level: INFO or DEBUG
EVENTMILL_LOG_LEVEL=INFO

# =============================================================================
# ttyd Web Terminal (Cloud Run deployment only)
# =============================================================================

# Username and password for the browser-based terminal login
# Change these from defaults before deploying
TTYD_USERNAME=analyst
TTYD_PASSWORD=changeme

# Maximum tools to expose per routing decision
EVENTMILL_MAX_CANDIDATE_TOOLS=5

# Default expansion mode: strict or adjacent
EVENTMILL_EXPANSION_MODE=strict

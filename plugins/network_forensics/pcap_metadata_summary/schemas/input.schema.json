{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "file_path": {
      "type": "string",
      "description": "Path to a .pcap or .pcapng file (local path or GCS URI)."
    },
    "mode": {
      "type": "string",
      "enum": ["load", "summary", "conversations", "dns", "http", "tls"],
      "default": "load",
      "description": "Operation mode: 'load' to parse a new PCAP, others to query the loaded session."
    },
    "top_n": {
      "type": "integer",
      "default": 20,
      "minimum": 1,
      "maximum": 200,
      "description": "Number of top entries to return (for conversations mode)."
    },
    "sort_by": {
      "type": "string",
      "enum": ["bytes", "packets", "duration"],
      "default": "bytes",
      "description": "Sort field for conversations mode."
    }
  },
  "required": ["file_path"]
}

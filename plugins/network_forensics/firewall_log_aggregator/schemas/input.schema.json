{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["load", "summary", "top_talkers", "deny_hotspots", "port_scan"],
      "default": "summary",
      "description": "Analysis mode."
    },
    "file_path": {
      "type": "string",
      "description": "Path to firewall log file."
    },
    "log_format": {
      "type": "string",
      "enum": ["auto", "paloalto_csv", "fortinet_syslog", "pfsense", "iptables", "windows_fw", "generic_csv"],
      "default": "auto",
      "description": "Log format. 'auto' attempts detection."
    },
    "top_n": {
      "type": "integer",
      "default": 20,
      "minimum": 1,
      "maximum": 200
    },
    "time_window_minutes": {
      "type": "integer",
      "default": 60,
      "description": "Time window for bucketed analysis."
    }
  },
  "required": ["file_path"]
}
